rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // 
    // Collection: projects
    // Fields: title, category, year, location, description, imageUrl, gallery[], stats[], order
    //
    // Collection: settings
    // Fields: philosophyTitle, philosophyDescription, contactEmail
    // ===============================================================

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "maahirvirsingh123@gmail.com" && request.auth.token.email_verified == true);
    }

    // Projects collection
    match /projects/{projectId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin();
    }

    // Settings collection
    match /settings/{settingId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin();
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
